# ==============================================================================
# DeepWiki 사내 온프레미스 환경 변수
# 이 파일을 .env로 복사하여 사용하세요: cp onpremise/.env.example .env
# ==============================================================================

# --- vLLM을 openai 프로바이더로 연결 ---
# vLLM은 OpenAI-compatible API이므로 기존 openai 프로바이더를 그대로 사용
OPENAI_API_KEY=dummy-key-for-vllm
OPENAI_BASE_URL=http://gpu-server-01.corp.local:8000/v1

# --- 임베딩: 내부 Ollama 사용 ---
DEEPWIKI_EMBEDDER_TYPE=ollama
OLLAMA_HOST=http://ollama:11434

# --- 커스텀 설정 디렉토리 ---
# docker-compose.override.yml에서 onpremise/config를 /app/custom-config로 마운트
DEEPWIKI_CONFIG_DIR=/app/custom-config

# --- 사내 CA 인증서 (빌드 시 사용, 빌드 컨텍스트 내 상대경로) ---
SSL_CERT_FILE=onpremise/certs/company-ca.crt

# --- 프록시 설정 (해당 시) ---
HTTP_PROXY=http://proxy.corp.local:8080
HTTPS_PROXY=http://proxy.corp.local:8080
NO_PROXY=localhost,127.0.0.1,gpu-server-01.corp.local,git.corp.local,ollama

# --- 서버 설정 ---
PORT=8001
SERVER_BASE_URL=http://localhost:8001
LOG_LEVEL=INFO

# --- 인증 (선택) ---
# DEEPWIKI_AUTH_MODE=true
# DEEPWIKI_AUTH_CODE=your-secret-code

# --- 아래 키는 vLLM+Ollama만 사용 시 불필요 ---
# GOOGLE_API_KEY=
# OPENROUTER_API_KEY=
